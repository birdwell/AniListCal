{
  "name": "anilistcal",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon",
    "client": "vite",
    "server:once": "tsx server/index.ts",
    "build": "cross-env NODE_ENV=production npx vite build && cross-env NODE_ENV=production npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:dev": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --sourcemap",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate": "graphql-codegen --config codegen.yml"
  },

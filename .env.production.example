# AniListCal Production Environment Configuration Example
# Copy this file to .env.production and fill in the values

# AniList OAuth credentials
ANILIST_CLIENT_ID=your_production_client_id
ANILIST_CLIENT_SECRET=your_production_client_secret
VITE_ANILIST_CLIENT_ID=your_production_client_id

# Session configuration - CHANGE THIS TO A STRONG RANDOM STRING
SESSION_SECRET=generate_a_strong_random_secret_here

# Server configuration
# Do NOT set PORT on Railway — the platform injects it. Hardcoding PORT=5001 causes 502 errors.
NODE_ENV=production

# Public URL of your Railway app (required for OAuth redirects after login)
# FRONTEND_URL=https://your-app.up.railway.app
# BACKEND_CALLBACK_URL=https://your-app.up.railway.app/api/auth/callback

# OpenAI API Key (if used)
OPENAI_API_KEY=your_openai_api_key

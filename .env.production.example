# AniListCal — production reference (set these in Railway/host dashboard, not in git)

NODE_ENV=production

# Required — from https://anilist.co/settings/developer
ANILIST_CLIENT_ID=your_production_client_id
ANILIST_CLIENT_SECRET=your_production_client_secret
VITE_ANILIST_CLIENT_ID=your_production_client_id

# Required — strong random string
SESSION_SECRET=generate_a_strong_random_secret_here

# Required for custom domain OAuth (example: anilistcal.com)
FRONTEND_URL=https://anilistcal.com
BACKEND_CALLBACK_URL=https://anilistcal.com/api/auth/callback

# Do NOT set PORT on Railway — the platform injects it.

# AniListCal — local development (.env in project root, never commit)

NODE_ENV=development

# Required — from https://anilist.co/settings/developer
# Redirect URI: http://localhost:5001/api/auth/callback
ANILIST_CLIENT_ID="your_anilist_client_id"
ANILIST_CLIENT_SECRET="your_anilist_client_secret"

# Not required — legacy client-side OAuth only (session auth uses /api/auth/login)
# VITE_ANILIST_CLIENT_ID="your_anilist_client_id"

# Required — any long random string
SESSION_SECRET="generate_a_strong_random_secret_key"

# Optional — session cookie lifetime in ms (default ~364 days, aligned with AniList token lifetime)
# SESSION_MAX_AGE_MS=31449600000

# Optional — Redis for durable sessions (required in production on Railway)
# Local dev works without this (in-memory sessions, lost on restart).
# REDIS_URL=redis://localhost:6379

# Optional — Express port (default 5001)
# PORT=5001

# Optional — open system browser on `yarn dev` (default true). Set false to disable.
# OPEN_BROWSER=false

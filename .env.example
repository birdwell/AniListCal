# AniListCal Environment Configuration

# Database connection (Example using local Postgres, replace with your connection string e.g., from Neon)
# DATABASE_URL=postgresql://username:password@localhost:5432/anilistcal
DATABASE_URL="your_database_connection_string_here"

# Server runtime environment (development, production, etc.)
NODE_ENV=development

# Port for the Express API (default 5001). For `yarn dev:all`, the script sets PORT=3001 so Vite on 5001 can proxy /api here.
# PORT=5001

# Split local dev only (`yarn dev:all`): must match the API port and AniList redirect URI (e.g. http://localhost:3001/api/auth/callback).
# VITE_BACKEND_ORIGIN=http://localhost:3001

# Open the system browser when the dev server starts (default: true). Set to false to disable.
# OPEN_BROWSER=false

# Secret key for signing session cookies (replace with a long, random string)
SESSION_SECRET="generate_a_strong_random_secret_key"

# AniList OAuth Credentials (Required - Obtain from AniList API settings)
# Used by the server for the OAuth token exchange
ANILIST_CLIENT_ID="your_anilist_client_id"
ANILIST_CLIENT_SECRET="your_anilist_client_secret"

# Used by the client-side Vite build process (must be prefixed with VITE_)
# Should be the same value as ANILIST_CLIENT_ID above
VITE_ANILIST_CLIENT_ID="your_anilist_client_id"
